# 研究 harness 统一密钥文件
# 用法: cp harness.env.example ~/agent-harnesses/harness.env 然后填入你自己的 key
# ⚠️ 填好的 harness.env 绝不要提交进任何仓库

# 必填:DeepSeek(所有引擎的主力 LLM) https://platform.deepseek.com
DEEPSEEK_API_KEY=replace_with_your_deepseek_key

# 必填:Tavily(所有引擎的搜索) 免费注册 https://tavily.com
# 多账号轮换可把 {"keys":["...","..."]} 保存到
# ~/.config/tavily/credentials.json (chmod 600)。TAVILY_API_KEY 仅作兼容回退。
TAVILY_CREDENTIALS_FILE=~/.config/tavily/credentials.json
TAVILY_API_KEY=replace_with_your_tavily_key

# GPT Researcher 的 embedding 需要(deepseek 无 embeddings 接口,用 Kimi coding 端点的 bge_m3)
# https://platform.moonshot.cn 或 Kimi Code 订阅
KIMI_API_KEY=replace_with_your_kimi_key

# 可选:DeerFlow 多模型(不填对应模型不可用,把 config 里对应段删掉即可)
ZHIPU_API_KEY=replace_with_your_zhipu_key
HUNYUAN_API_KEY=replace_with_your_hunyuan_key

# 可选:Obsidian/LlamaIndex 私人知识库索引范围
# 可选:填写你自己的 Obsidian vault 绝对路径;留空不启用 vault 索引。
# 启用后只读其中的 .md/.txt,并可索引本机 CodeWhale/Codex 对话记录的脱敏派生 markdown;不会全盘扫描。
OBSIDIAN_VAULT=
# 设为 0 可关闭对应工作记录来源
OBSIDIAN_INCLUDE_CODEWHALE=1
OBSIDIAN_INCLUDE_CODEX=1
# 默认最多索引最近 300 个 CodeWhale thread、500 个 Codex session;设为 0 表示不限制
OBSIDIAN_CODEWHALE_MAX_THREADS=300
OBSIDIAN_CODEX_MAX_SESSIONS=500
# 默认 mock 避免首次下载 HuggingFace 模型;想用本地语义 embedding 可填模型名
OBSIDIAN_EMBED_MODEL=mock
